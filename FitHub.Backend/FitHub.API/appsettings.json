{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": { "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}" }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "shared": true,
          "outputTemplate": "[{Application}][{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithProcessId", "WithMachineName" ]
  },
  "ConnectionStrings": {
    "Main": "Server=(localdb)\\MSSQLLocalDB;Database=FitHubDb;Trusted_Connection=True;"
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "FitHub.Api",
    "Audience": "FitHub.Spa",
    "Key": "DEV_ONLY_CHANGE_ME_TO_LONG_RANDOM_SECRET",
    "AccessTokenMinutes": 20,
    "RefreshTokenDays": 14
  },
  "Captcha": {
    "Enabled": "true",
    "SecretKey": " "
  },
 "FrontendUrl" : "http://localhost:4200",
    "Authentication": {
    "GoogleClientId": "638693312621-rinh0mhb00cj633infu3n96nsf0nccp2.apps.googleusercontent.com",
    "FacebookAppId": "1420849872479873"
  }
}
